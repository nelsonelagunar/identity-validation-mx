# Environment variables
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mexico_identity
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_DAY=10000

# CORS
CORS_ORIGINS=["*"]

# External APIs (Demo mode)
RENAPO_API_URL=https://demo.renapo.gob.mx/api
SAT_API_URL=https://demo.sat.gob.mx/api
INE_API_URL=https://demo.ine.mx/api