# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=identity_user
DB_PASSWORD=your_secure_password
DB_NAME=identity_validation
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=100
DB_MAX_IDLE_CONNECTIONS=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# API Configuration
API_VERSION=v1
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=1m

# API Keys (comma-separated)
API_KEYS=api_key_dev_123,api_key_prod_456

# TLS Configuration
TLS_ENABLED=false
TLS_CERT_FILE=./certs/server.crt
TLS_KEY_FILE=./certs/server.key

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Biometric Service Configuration (External API)
BIOMETRIC_ENABLED=true
BIOMETRIC_PROVIDER=mock
BIOMETRIC_API_URL=http://localhost:5001
BIOMETRIC_API_KEY=your_biometric_api_key

# Signature Service Configuration
SIGNATURE_ENABLED=true
SIGNATURE_CERT_PATH=./certs/signing.p12
SIGNATURE_CERT_PASSWORD=your_cert_password

# Bulk Import Configuration
BULK_IMPORT_MAX_FILE_SIZE=10485760
BULK_IMPORT_MAX_RECORDS=10000
BULK_IMPORT_WORKERS=4

# Webhook Configuration
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT=30s
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=1s

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key
CORS_MAX_AGE=86400

# Security Configuration
SECURITY_BCRYPT_COST=12
SECURITY_JWT_SECRET=your_jwt_secret_key
SECURITY_JWT_EXPIRY=24h

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_ENABLED=true
READY_ENABLED=true
